# ─── HYDRA Venture Studio Engine — Environment Variables ───────────────────────
# Copie para .env.hydra e preencha os valores reais.
# NUNCA commite .env.hydra com valores reais — apenas este .example.
# ──────────────────────────────────────────────────────────────────────────────

# ─── LLM (Anthropic) ──────────────────────────────────────────────────────────
HYDRA_ANTHROPIC_API_KEY=
HYDRA_PRIMARY_MODEL=claude-sonnet-4-6
HYDRA_FALLBACK_MODEL=claude-haiku-4-5-20251001
HYDRA_MAX_TOKENS=4096

# ─── Supabase ─────────────────────────────────────────────────────────────────
HYDRA_SUPABASE_URL=
HYDRA_SUPABASE_ANON_KEY=
HYDRA_SUPABASE_SERVICE_KEY=

# ─── Telegram ─────────────────────────────────────────────────────────────────
HYDRA_TELEGRAM_BOT_TOKEN=
HYDRA_TELEGRAM_CHAT_ID=1069502175

# ─── Budget ───────────────────────────────────────────────────────────────────
HYDRA_SEED_CAPITAL_BRL=1000
HYDRA_MVP_BUDGET_BRL=200
HYDRA_BUDGET_ALERT_PCT=0.5

# ─── Feature Flags ────────────────────────────────────────────────────────────
# true = simula chamadas LLM e Supabase sem gastar créditos
HYDRA_DRY_RUN=true
