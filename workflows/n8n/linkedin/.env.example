# Copiar variáveis para o Coolify (Secrets) ou para arquivo .env do compose (não versionar valores reais).

# URL pública HTTPS do n8n (ex.: https://n8n.adventurelabs.com.br/)
WEBHOOK_URL=

# Chave de criptografia do n8n (32+ caracteres aleatórios, persistir no vault)
N8N_ENCRYPTION_KEY=

# Host do domínio público (sem https://), alinhado ao certificado
N8N_HOST=

# Edge Function Supabase (ingestão LinkedIn) — slug canónico no repo: linkedin-native-lead-submit
# Não confundir com linkedin_native_lead (outra função / legado no Dashboard).
LINKEDIN_EDGE_FUNCTION_URL=https://[PROJECT_REF].supabase.co/functions/v1/linkedin-native-lead-submit

# Mesmo valor configurado em Supabase (secret LINKEDIN_WEBHOOK_SECRET)
LINKEDIN_WEBHOOK_SECRET=

# Chave anon do projeto Supabase (headers apikey + Authorization nas invocações HTTP)
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
