# Copie para .env nesta pasta (não versionar).

ASANA_OAUTH_CLIENT_ID=
ASANA_OAUTH_CLIENT_SECRET=

# Opcional — só para oauth-oob (código na página Asana):
# ASANA_OAUTH_SCOPES=openid email profile default identity

# Fluxo localhost (oauth): no app Asana, Redirect URL = http://127.0.0.1:47823/callback
# Fluxo OOB (oauth-oob): no app Asana, Redirect URL = urn:ietf:wg:oauth:2.0:oob
