# /opt/adventure-labs/.env — Variáveis de ambiente da VPS Adventure Labs
# NUNCA commitar este arquivo com valores reais.
# Copiar para /opt/adventure-labs/.env na VPS e preencher os valores via Infisical.

# ── Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<bot_token>
TELEGRAM_CHAT_ID=<chat_id>

# ── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<service_role_key>

# ── N8N ──────────────────────────────────────────────────────────────
N8N_API_KEY=<n8n_api_key>
N8N_ENCRYPTION_KEY=<encryption_key>
N8N_USER_MANAGEMENT_JWT_SECRET=<jwt_secret>
INFISICAL_TOKEN=<infisical_token>

# ── Google Drive (rclone) ────────────────────────────────────────────
# Configurado via: rclone config (gdrive-adventure)

# ── Mercado Pago ─────────────────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=<access_token>

# ── Evolution API ────────────────────────────────────────────────────
EVOLUTION_API_KEY=<api_key>
