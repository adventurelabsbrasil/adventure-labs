# Copiar para .env e preencher antes de rodar docker compose
# Gerar chaves: openssl rand -hex 16 (ENCRYPTION_KEY) | openssl rand -base64 32 (AUTH_SECRET)

POSTGRES_PASSWORD=troque-por-senha-forte

# Infisical — gerar com: openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=

# Infisical — gerar com: openssl rand -base64 32
INFISICAL_AUTH_SECRET=

# Telegram (opcional, para notificações do adventure_ops.sh)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
