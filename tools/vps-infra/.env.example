# =============================================================================
# Adventure Labs VPS — Variáveis de Ambiente
# Copiar para .env e preencher ANTES de rodar docker compose up -d
# Nunca commitar o .env com valores reais — usar Infisical /admin como SSOT
# =============================================================================

# --- PostgreSQL (banco compartilhado) ----------------------------------------
POSTGRES_PASSWORD=troque-por-senha-forte

# --- Infisical (cofre de segredos) -------------------------------------------
# Gerar com: openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=
# Gerar com: openssl rand -base64 32
INFISICAL_AUTH_SECRET=

# --- Evolution API (WhatsApp) ------------------------------------------------
# Chave global de autenticação do Evolution API
# Encontrada em: docker exec adventure-evolution printenv AUTHENTICATION_API_KEY
EVOLUTION_API_KEY=

# --- Anthropic (LLM primário do dispatcher adventure-agent.sh) ---------------
# Criar em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- Gemini (Google AI) — fallback LLM #1 do dispatcher ---------------------
# Criar em: aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- OpenAI — fallback LLM #2 do dispatcher ----------------------------------
# Criar em: platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Mistral (embeddings — substitui Google text-embedding-004) --------------
# Criar em: console.mistral.ai → API Keys
# Modelo: mistral-embed (1024 dimensões) → gravado em adv_csuite_memory.embedding
# NOTA: se adv_csuite_memory.embedding for vector(1536), rodar na VPS:
#   ALTER TABLE adv_csuite_memory ALTER COLUMN embedding TYPE vector(1024)
#     USING embedding::text::vector(1024);
MISTRAL_API_KEY=

# --- n8n ---------------------------------------------------------------------
# Usuário e senha do painel n8n (flow.adventurelabs.com.br)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# --- Supabase ----------------------------------------------------------------
# URL base da API REST (sem barra no final)
SUPABASE_URL=https://ftctmseyrqhckutpfdeq.supabase.co
# Connection string direta (porta 5432, não pooler) — usada pelo dispatcher psql
SUPABASE_DB_URL=postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres
# Anon key pública (usada no frontend)
SUPABASE_ANON_KEY=
# Service role key (usada em backends/workflows — manter segura)
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Drive OAuth (para workflow 02 — Sincronizador SSOT) --------------
# Criar em: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Após autorizar no n8n, o refresh_token será salvo automaticamente

# --- Asana (para workflow 03 — Transcrição WhatsApp → Task) ------------------
# Criar em: app.asana.com/0/my-profile/apps → Personal Access Tokens
ASANA_PAT=
# GID do workspace Adventure Labs (aparece na URL do Asana)
ASANA_WORKSPACE_GID=

# --- Telegram (notificações do adventure_ops.sh) -----------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Metabase ----------------------------------------------------------------
# Configurado via UI em http://187.77.251.199:3000 (ou bi.adventurelabs.com.br após TLS)
# Credenciais de conexão ao Supabase para adicionar no painel Metabase:
# Host: db.[REF].supabase.co  Port: 5432
# User: postgres  Password: [SUPABASE_DB_PASSWORD]  DB: postgres
