# Dbgr – copie para .env e preencha. Nunca commite o .env.

# === Obrigatório para config domain e para debug completo (Vercel) ===
# Onde obter: https://vercel.com/account/tokens → Create (token da CONTA, não do projeto – está correto)
# Permissões: Full Account (ou leitura de projetos/domínios + adicionar domínios)
VERCEL_TOKEN=

# === Opcional: Wix (Dbgr usa pouco – API Wix não expõe email/DNS do plano comercial) ===
# WIX_API_KEY: expira em ~20 min; gere de novo em https://dev.wix.com se precisar rodar de novo.
# WIX_SITE_ID: use só o GUID do site. Ex.: na URL https://manage.wix.com/dashboard/212a1607-bae9-4a3d-9c23-a6abba7c91b7 o ID é 212a1607-bae9-4a3d-9c23-a6abba7c91b7. Se colar algo com ?metaSiteId=..., o Dbgr usa o metaSiteId.
WIX_API_KEY=
WIX_SITE_ID=

# === Alvo do projeto (valores padrão dos comandos) ===
TARGET_DOMAIN=capclear.com.br
TARGET_EMAIL=contato@capclear.com.br

# === Não coloque no .env ===
# A senha do email (ex.: CapClear26) e a senha do Wix não são usadas pelo Dbgr.
# Use-as só no navegador: Admin Console do Google, Gmail, painel Wix.
