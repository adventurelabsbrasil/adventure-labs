# Porta do servidor HTTP (default 3333)
PORT=3333

# Pasta onde a sessão WhatsApp (LocalAuth) será persistida (default .wwebjs_auth)
SESSION_PATH=.wwebjs_auth

# Grupos a serem lidos (adv_zazu — grupos iniciais). Use um dos dois:
# 1) IDs exatos dos grupos (como retornados por GET /groups)
WHATSAPP_GROUP_IDS=

# 2) Nomes parciais (case-insensitive; match por includes). Valores com espaço: use aspas.
# Grupos iniciais: Adventure Young, Adventure Benditta, Adventure Rose, Adventure Tráfego Pago
WHATSAPP_GROUP_NAMES="Adventure Young,Adventure Benditta,Adventure Rose,Adventure Tráfego Pago"

# Se ambos estiverem vazios, todos os grupos serão considerados (use com cuidado).
