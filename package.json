{
  "name": "adventure-labs-monorepo",
  "private": true,
  "description": "Raiz do monorepo — use pnpm install na raiz ou npm install em cada app (apps/admin, etc.)",
  "scripts": {
    "admin:dev": "pnpm --filter adventure-labs-admin dev",
    "test:andon": "pnpm --filter adventure-labs-admin run test:andon",
    "test:andon:post": "pnpm --filter adventure-labs-admin run test:andon:post",
    "admin:install": "pnpm --filter adventure-labs-admin install",
    "sync": "cd apps/admin && pnpm run sync:context",
    "railway": "railway",
    "railway:link": "railway link",
    "railway:status": "railway status",
    "railway:logs": "railway logs",
    "xpostr:dev": "pnpm --filter adventure-labs-xpostr dev",
    "benditta:dev": "pnpm --filter benditta-dashboard dev"
  },
  "devDependencies": {
    "@railway/cli": "^4.31.0"
  }
}
