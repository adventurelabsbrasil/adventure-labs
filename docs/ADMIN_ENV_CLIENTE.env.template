# =============================================================================
# Admin por cliente — template de variáveis de ambiente
# =============================================================================
# Use este arquivo como base para cada cliente. Para o cliente XX_nome:
#   1. Copie para clients/XX_nome/admin/.env.example e preencha os valores.
#   2. No Vercel do subdomínio desse cliente, crie as mesmas variáveis (Settings → Environment Variables).
#   3. Em desenvolvimento local para esse cliente: copie para apps/admin/.env.local
#      (ou use um symlink / script que carrega clients/XX_nome/admin/.env).
#
# Cada subdomínio (ex.: lidera.admin.adventurelabs.com.br) = um projeto Vercel = este env.
# =============================================================================

# -----------------------------------------------------------------------------
# Identificação do cliente (para referência; não usado pelo app)
# -----------------------------------------------------------------------------
# CLIENTE_ID=lidera
# CLIENTE_NOME=Lidera

# -----------------------------------------------------------------------------
# Supabase (obrigatório)
# Pode ser o mesmo projeto para todos os clientes ou um projeto por cliente.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# Segurança e allowlist
# E-mails que podem acessar este admin (vírgula sem espaço).
# -----------------------------------------------------------------------------
ADMIN_ALLOWED_EMAILS=contato@adventurelabs.com.br,rodrigo.ribas1991@gmail.com

# -----------------------------------------------------------------------------
# URL do Admin DESTE CLIENTE (subdomínio em produção)
# Ex.: https://lidera.admin.adventurelabs.com.br
# Em local pode omitir ou usar http://localhost:3001
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://CLIENTE.admin.adventurelabs.com.br

# CRON_SECRET: invente um valor (openssl rand -hex 32). Mesmo no .env.local e na Vercel.
CRON_SECRET=your_cron_secret_here

# Redirect URLs no Supabase (Auth → URL Configuration): incluir o domínio deste cliente.
#   Local:   http://localhost:3001/auth/callback
#   Produção: https://CLIENTE.admin.adventurelabs.com.br/auth/callback

# -----------------------------------------------------------------------------
# n8n (opcional)
# -----------------------------------------------------------------------------
# N8N_API_URL=
# N8N_API_TOKEN=
# N8N_WEBHOOK_CREATE_ISSUE=
# N8N_WEBHOOK_TAREFA_CONCLUIDA=

# -----------------------------------------------------------------------------
# Gemini (opcional)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# GitHub (opcional)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=
# GITHUB_REPO_OWNER=adventurelabsbrasil
# GITHUB_REPO_NAME=admin

# -----------------------------------------------------------------------------
# Google Drive — credenciais DESTE CLIENTE (pasta/contas dele)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REFRESH_TOKEN=1//xxx
GOOGLE_DRIVE_FOLDER_ID=root

# -----------------------------------------------------------------------------
# Google Ads — conta DESTE CLIENTE
# -----------------------------------------------------------------------------
GOOGLE_ADS_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_REFRESH_TOKEN=1//xxx
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# -----------------------------------------------------------------------------
# Meta Business Manager / Ads — DESTE CLIENTE (System User token com acesso às contas dele)
# -----------------------------------------------------------------------------
META_BM_SYSTEM_USER_TOKEN=your_system_user_token_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
