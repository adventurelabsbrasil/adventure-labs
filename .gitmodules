# Adventure Labs — Submodules
# Critério: apps com deploy próprio, CI independente ou repo externo → submodule
# Apps internos sem deploy independente → workspace local em apps/clientes/ ou apps/labs/
# Atualizar submodules: git submodule update --remote --merge

# ─── Core Products ────────────────────────────────────────────────────────────
[submodule "apps/core/admin"]
	path = apps/core/admin
	url = https://github.com/adventurelabsbrasil/admin.git
	branch = main

[submodule "apps/core/adventure"]
	path = apps/core/adventure
	url = https://github.com/adventurelabsbrasil/adventure.git
	branch = main

[submodule "apps/core/elite"]
	path = apps/core/elite
	url = https://github.com/adventurelabsbrasil/elite.git
	branch = main

# ─── Labs (avaliar migração para local se inativos) ───────────────────────────
[submodule "apps/labs/finfeed"]
	path = apps/labs/finfeed
	url = https://github.com/adventurelabsbrasil/finfeed.git
	branch = main

[submodule "apps/labs/whatsapp-worker"]
	path = apps/labs/whatsapp-worker
	url = https://github.com/adventurelabsbrasil/adv-zazu-whatsapp-worker.git
	branch = main

