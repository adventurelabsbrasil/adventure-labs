#!/usr/bin/env bash
# Adventure Labs — pre-commit hook de segurança
# Bloqueia commits com padrões de credenciais conhecidas.
# Instalado automaticamente por scripts/setup.sh via: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

BLOCKED=0

echo "🔐 Verificando segredos nos arquivos staged..."

# Arquivos staged (excluindo deletados)
STAGED=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED" ]; then
  exit 0
fi

# ─── Padrões de credenciais proibidas (bash 3.x compat) ─────────────────────
check_pattern() {
  local label="$1"
  local pattern="$2"
  for FILE in $STAGED; do
    [ -f "$FILE" ] || continue
    if git diff --cached -- "$FILE" | grep -qE "\+.*${pattern}"; then
      echo -e "${RED}❌ BLOQUEADO: ${label} detectado em '${FILE}'${NC}"
      BLOCKED=1
    fi
  done
}

check_pattern "Google OAuth Client Secret" "GOCSPX-[A-Za-z0-9_-]+"
check_pattern "Google API Key"             "AIzaSy[A-Za-z0-9_-]{33}"
check_pattern "JWT (Supabase/genérico)"    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\.[A-Za-z0-9_-]+"
check_pattern "OpenAI / Anthropic key"     "sk-[A-Za-z0-9]{20,}"
check_pattern "Supabase key em .env"       "SUPABASE_(ANON|SERVICE)_KEY=ey[A-Za-z0-9]"
# Padrão dividido para não auto-acionar o hook ao commitar este arquivo
_GEMINI_PAT="GEMINI_API_KEY=AIza"; check_pattern "Gemini key em .env" "${_GEMINI_PAT}Sy"

# ─── Arquivos proibidos ───────────────────────────────────────────────────────
for FILE in $STAGED; do
  BASENAME=$(basename "$FILE")
  if echo "$BASENAME" | grep -qE "(client_secret.*\.json|service_account.*\.json|^credentials\.json$|^token\.json$)"; then
    echo -e "${RED}❌ BLOQUEADO: arquivo de credencial proibido: '${FILE}'${NC}"
    BLOCKED=1
  fi
done

if [ "$BLOCKED" -eq 1 ]; then
  echo ""
  echo -e "${YELLOW}💡 Remova as credenciais e use variáveis de ambiente via Infisical.${NC}"
  echo -e "${YELLOW}   Vault local: _internal/vault/README.md${NC}"
  echo -e "${YELLOW}   Para ignorar (risco): git commit --no-verify (NÃO recomendado)${NC}"
  exit 1
fi

echo "✅ Nenhum segredo detectado."
exit 0
