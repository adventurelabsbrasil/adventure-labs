#!/usr/bin/env bash
# Adventure Labs — pre-commit hook de segurança
# Bloqueia commits com padrões de credenciais conhecidas.
# Instalado automaticamente por scripts/setup.sh via: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

BLOCKED=0

echo "🔐 Verificando segredos nos arquivos staged..."

# Arquivos staged (excluindo deletados)
STAGED=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED" ]; then
  exit 0
fi

# ─── Padrões de credenciais proibidas ──────────────────────────────────────
declare -A PATTERNS
PATTERNS["Google OAuth Client Secret"]="GOCSPX-[A-Za-z0-9_-]+"
PATTERNS["Google API Key"]="AIzaSy[A-Za-z0-9_-]{33}"
PATTERNS["Supabase JWT (anon/service_role)"]="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+"
PATTERNS["OpenAI / Anthropic secret key"]="sk-[A-Za-z0-9]{20,}"
PATTERNS["Supabase key em .env.example"]="SUPABASE_(ANON|SERVICE)_KEY=ey[A-Za-z0-9]"
PATTERNS["Gemini API key em .env.example"]="GEMINI_API_KEY=AIzaSy"

for FILE in $STAGED; do
  # Pular binários e arquivos deletados
  [ -f "$FILE" ] || continue

  for LABEL in "${!PATTERNS[@]}"; do
    PATTERN="${PATTERNS[$LABEL]}"
    if git diff --cached -- "$FILE" | grep -qE "\+.*${PATTERN}"; then
      echo -e "${RED}❌ BLOQUEADO: ${LABEL} detectado em '${FILE}'${NC}"
      BLOCKED=1
    fi
  done
done

# ─── Arquivos proibidos ─────────────────────────────────────────────────────
FORBIDDEN_PATTERNS=(
  "client_secret.*\.json"
  "service_account.*\.json"
  "^credentials\.json$"
  "^token\.json$"
)

for FILE in $STAGED; do
  BASENAME=$(basename "$FILE")
  for PAT in "${FORBIDDEN_PATTERNS[@]}"; do
    if echo "$BASENAME" | grep -qE "$PAT"; then
      echo -e "${RED}❌ BLOQUEADO: arquivo proibido staged: '${FILE}'${NC}"
      BLOCKED=1
    fi
  done
done

if [ "$BLOCKED" -eq 1 ]; then
  echo ""
  echo -e "${YELLOW}💡 Remova as credenciais e use variáveis de ambiente via Infisical.${NC}"
  echo -e "${YELLOW}   Vault local: _internal/vault/README.md${NC}"
  echo -e "${YELLOW}   Para ignorar (risco): git commit --no-verify (NÃO recomendado)${NC}"
  exit 1
fi

echo "✅ Nenhum segredo detectado."
exit 0
